    "paths": {
        "/activities/{activity}/registrations": {
            "get": {
                "tags": [
                    "Activity"
                ],
                "summary": "List Registrations",
                "description": "Lists all registrations for a given activity.",
                "operationId": "27e0c747a05d7aa73e7fdbb73687d6f9",
                "parameters": [
                    {
                        "name": "activity",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    },
                    {
                        "$ref": "#/components/parameters/PageParameter"
                    },
                    {
                        "$ref": "#/components/parameters/PerPageParameter"
                    },
                    {
                        "$ref": "#/components/parameters/SearchParameter"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated list of registrations.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "code": {
                                            "type": "string",
                                            "example": "SUCCESS"
                                        },
                                        "data": {
                                            "properties": {
                                                "registrations": {
                                                    "description": "Paginated resource object.",
                                                    "properties": {
                                                        "data": {
                                                            "description": "List of resources in current page.",
                                                            "type": "array",
                                                            "items": {
                                                                "$ref": "#/components/schemas/ActivityRegistrationResource"
                                                            }
                                                        },
                                                        "meta": {
                                                            "$ref": "#/components/schemas/PaginationMeta"
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthenticatedResponse"
                    },
                    "403": {
                        "$ref": "#/components/responses/UnauthorizedResponse"
                    }
                }
            }
        },
        "/activities/{activity}": {
            "get": {
                "tags": [
                    "Activity"
                ],
                "summary": "Show Activity",
                "description": "Returns the detail of a given activity.",
                "operationId": "f37310cd7d6937a6865f4d6176101cfa",
                "parameters": [
                    {
                        "name": "activity",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Activity detail.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "code": {
                                            "type": "string",
                                            "example": "SUCCESS"
                                        },
                                        "data": {
                                            "properties": {
                                                "activity": {
                                                    "$ref": "#/components/schemas/ActivityResource"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthenticatedResponse"
                    },
                    "404": {
                        "$ref": "#/components/responses/NotFoundResponse"
                    },
                    "403": {
                        "$ref": "#/components/responses/UnauthorizedResponse"
                    }
                }
            }
        },
        "/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login",
                "description": "Creates token for user based on given credentials.",
                "operationId": "549b3b7585a3bbf2a9cea6d46d145fac",
                "requestBody": {
                    "$ref": "#/components/requestBodies/LoginRequest"
                },
                "responses": {
                    "200": {
                        "$ref": "#/components/responses/UserWithTokenResponse"
                    },
                    "401": {
                        "description": "Invalid credentials.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "code": {
                                            "type": "string",
                                            "example": "INVALID_CREDENTIALS"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/InvalidContentResponse"
                    }
                }
            }
        },
        "/auth/login/social/{provider}": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login Via Social",
                "description": "Creates token for user based on given token from social auth provider.",
                "operationId": "9d4c29c18b9b58b44c27e4566ec25a47",
                "parameters": [
                    {
                        "name": "provider",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "google"
                            ]
                        }
                    }
                ],
                "requestBody": {
                    "$ref": "#/components/requestBodies/LoginViaSocialRequest"
                },
                "responses": {
                    "200": {
                        "$ref": "#/components/responses/UserWithTokenResponse"
                    },
                    "422": {
                        "$ref": "#/components/responses/InvalidContentResponse"
                    }
                }
            }
        },
        "/auth/logout": {
            "delete": {
                "tags": [
                    "Auth"
                ],
                "summary": "Logout",
                "description": "Destroys current user's token",
                "operationId": "621e0196dcdb26b7bd3bf475b66a8369",
                "responses": {
                    "200": {
                        "description": "Logged out successfully.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "code": {
                                            "type": "string",
                                            "example": "SUCCESS"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthenticatedResponse"
                    }
                }
            }
        },
        "/auth/me": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Me",
                "description": "Gets info about currently logged in user.",
                "operationId": "3f60056c38016ff4b89228ab66dd2ae9",
                "responses": {
                    "200": {
                        "description": "User data.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "code": {
                                            "type": "string",
                                            "example": "SUCCESS"
                                        },
                                        "data": {
                                            "properties": {
                                                "user": {
                                                    "$ref": "#/components/schemas/MeResource"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthenticatedResponse"
                    }
                }
            }
        },
        "/users/me/activities": {
            "get": {
                "tags": [
                    "User"
                ],
                "summary": "My activities",
                "description": "Lists currently logged in user's activities.",
                "operationId": "4899471515139914da2e5571ce014aac",
                "parameters": [
                    {
                        "name": "filter",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "nullable": true,
                            "enum": [
                                "draft",
                                "upcoming",
                                "ongoing"
                            ]
                        }
                    },
                    {
                        "$ref": "#/components/parameters/PageParameter"
                    },
                    {
                        "$ref": "#/components/parameters/PerPageParameter"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated list of activities.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "code": {
                                            "type": "string",
                                            "example": "SUCCESS"
                                        },
                                        "data": {
                                            "properties": {
                                                "activities": {
                                                    "description": "Paginated resource object.",
                                                    "properties": {
                                                        "data": {
                                                            "description": "List of resources in current page.",
                                                            "type": "array",
                                                            "items": {
                                                                "$ref": "#/components/schemas/MyActivityResource"
                                                            }
                                                        },
                                                        "meta": {
                                                            "$ref": "#/components/schemas/PaginationMeta"
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthenticatedResponse"
                    }
                }
            }
        }
    },
