                        "schema": {
                            "properties": {
                                "code": {
                                    "type": "string",
                                    "example": "SUCCESS"
                                },
                                "data": {
                                    "properties": {
                                        "token": {
                                            "type": "string",
                                            "example": "7|GEApizQYN8..."
