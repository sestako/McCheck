# Copy to `.env` in this folder (mobile/). See docs/mcheck-implementation-plan.md

# MoveConcept API (no trailing slash). Same default as app + EAS production/preview profiles.
EXPO_PUBLIC_API_BASE_URL=https://staging.moveconcept.cz

# Daily dev: omit this or set to true — mock API, no backend (recommended).
# Staging integration: set to false and use real base URL (see docs/mcheck-phase-a.md).
# EXPO_PUBLIC_USE_MOCK_API=false

# Optional auth path overrides (if backend uses different routes).
# Must include `/auth/` — `/api/login` returns 404 on MoveConcept; use `/api/auth/login`.
# EXPO_PUBLIC_AUTH_LOGIN_PATH=/api/auth/login
# EXPO_PUBLIC_AUTH_ME_PATH=/api/auth/me
# EXPO_PUBLIC_AUTH_LOGOUT_PATH=/api/auth/logout
# Optional override for Google social token exchange (default: /api/auth/login/social/google).
# EXPO_PUBLIC_AUTH_GOOGLE_SOCIAL_PATH=/api/auth/login/social/google

# Google Sign-In (required when EXPO_PUBLIC_USE_MOCK_API=false for real Google OAuth).
# Create OAuth 2.0 client IDs in Google Cloud Console (Web + iOS + Android as needed).
# For Expo Go / dev, add authorized redirect URI: https://auth.expo.io/@YOUR_EXPO_ACCOUNT/mccheck
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Mock-only error/edge QA (only when mock API is on). Omit = normal mock behavior.
# login_fail | activities_fail | detail_404 | guests_403 | edge_layout
# EXPO_PUBLIC_MOCK_SCENARIO=edge_layout

# Optional crash reporting (wire Sentry in src/lib/observability.ts when ready)
# EXPO_PUBLIC_SENTRY_DSN=
