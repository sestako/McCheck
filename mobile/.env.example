# Copy to `.env` in this folder (mobile/). See docs/mcheck-implementation-plan.md

# MoveConcept API (no trailing slash). Placeholder OK until staging URL exists.
EXPO_PUBLIC_API_BASE_URL=https://your-staging.moveconcept.example

# Daily dev: omit this or set to true — mock API, no backend (recommended).
# Staging integration: set to false and use real base URL (see docs/mcheck-phase-a.md).
# EXPO_PUBLIC_USE_MOCK_API=false

# Optional auth path overrides (if backend uses different routes):
# EXPO_PUBLIC_AUTH_LOGIN_PATH=/api/login
# EXPO_PUBLIC_AUTH_ME_PATH=/api/user
# EXPO_PUBLIC_AUTH_LOGOUT_PATH=/api/logout

# Mock-only error/edge QA (only when mock API is on). Omit = normal mock behavior.
# login_fail | activities_fail | detail_404 | guests_403 | edge_layout
# EXPO_PUBLIC_MOCK_SCENARIO=edge_layout

# Optional crash reporting (wire Sentry in src/lib/observability.ts when ready)
# EXPO_PUBLIC_SENTRY_DSN=
