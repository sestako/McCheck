{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://staging.moveconcept.cz",
        "EXPO_PUBLIC_USE_MOCK_API": "false",
        "EXPO_PUBLIC_AUTH_LOGIN_PATH": "/api/auth/login",
        "EXPO_PUBLIC_AUTH_ME_PATH": "/api/auth/me",
        "EXPO_PUBLIC_AUTH_LOGOUT_PATH": "/api/auth/logout"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://staging.moveconcept.cz",
        "EXPO_PUBLIC_USE_MOCK_API": "false",
        "EXPO_PUBLIC_AUTH_LOGIN_PATH": "/api/auth/login",
        "EXPO_PUBLIC_AUTH_ME_PATH": "/api/auth/me",
        "EXPO_PUBLIC_AUTH_LOGOUT_PATH": "/api/auth/logout"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6761914645"
      }
    }
  }
}
